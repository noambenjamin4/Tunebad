# Optional: override the yt-dlp binary location (defaults to ./bin/yt-dlp, then PATH)
# YT_DLP_PATH=/usr/local/bin/yt-dlp

# Optional Supabase backend for analysis history persistence.
# Leave both blank to use localStorage-only history (the default; no setup needed).
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Link downloader (YouTube/SoundCloud/etc. -> MP3/WAV). This shells out to
# yt-dlp + ffmpeg and cannot run on serverless hosts like Vercel, so it's off
# by default. Set BOTH to "1" for local development if you want it enabled;
# leave both "0" (or unset) in production/Vercel deployments.
ENABLE_LINK_DOWNLOADER=0
NEXT_PUBLIC_DOWNLOADER=0

# Optional: proxy the link downloader to a self-hosted remote server (see
# server/) instead of shelling out locally. Required together on Vercel if you
# want the downloader to work in production; leave both blank otherwise.
# DOWNLOADER_REMOTE_URL=https://your-downloader.onrender.com
# DOWNLOADER_API_KEY=

# Optional: a second copy of the same server/ running on a home machine,
# reached via a tunnel URL. Preferred over DOWNLOADER_REMOTE_URL when
# reachable (YouTube bot-walls the Render datacenter IP but not a home IP);
# falls back to the remote pair above when this is unset or unreachable.
# DOWNLOADER_HOME_URL=https://your-tunnel-host.example.com
# DOWNLOADER_HOME_KEY=
